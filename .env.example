# Copy this file to .env (or .env.local) and fill in real values.
# Real .env / .env.local files are gitignored. Never commit secrets.

# ──────────────────────────────────────────────────────────────────────────────
# Neon Postgres (used by Prisma)
# ──────────────────────────────────────────────────────────────────────────────
#
# DATABASE_URL: pooled connection — host usually contains "-pooler" (Neon pooler).
# Used by the app at runtime (Next.js API routes, Vercel serverless).
#
# IMPORTANT: append &pgbouncer=true&connection_limit=1 (or add to existing query string)
# because PgBouncer-style poolers do not support prepared statements; Prisma needs this hint.
#
# Example (adjust user, password, host, database name to match your Neon project):
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1"
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1"

# DIRECT_URL: direct connection — same user/db but host WITHOUT "-pooler".
# Used ONLY by `prisma migrate` (schema migrations). Do NOT add pgbouncer=true here.
#
# Example:
# DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# If your password contains @ : / ? # etc., URL-encode it in both URLs.

# ──────────────────────────────────────────────────────────────────────────────
# WebAuthn (passkeys)
# ──────────────────────────────────────────────────────────────────────────────
# Relying-party host (no scheme, no port). In dev, "localhost" is fine.
WEBAUTHN_RP_ID="localhost"
# Full origin including scheme and port. In dev, match your dev server (e.g. http://localhost:3001).
WEBAUTHN_ORIGIN="http://localhost:3000"
# Comma-separated Chrome extension IDs (32-char [a-p]) allowed for extension-page WebAuthn.
# Required when the extension sends `chromeExtensionId` on registration/authentication begin.
# WEBAUTHN_EXTENSION_IDS="abcdefghijklmnopabcdefghijklmnop"
#
# Comma-separated exact origins allowed for credentialed CORS on `/api/*` (https app + each chrome-extension://id).
# Required for extension `fetch(..., { credentials: "include" })` against this API host.
# API_CORS_ALLOWED_ORIGINS="http://localhost:3000,chrome-extension://abcdefghijklmnopabcdefghijklmnop"

# ──────────────────────────────────────────────────────────────────────────────
